# ── ThermalEye API — copy to .env and fill in (NEVER commit the real .env) ──

# Environment: development | production
ENVIRONMENT=development

# --- Database (Supabase Postgres) ---
# Use the Session pooler / direct connection for the async app.
# Async driver form: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/thermaleye
# Sync form used by Alembic migrations (psycopg): postgresql+psycopg://...
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@localhost:5432/thermaleye

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-generate-a-64-byte-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- CORS (comma-separated origins allowed to call the API) ---
CORS_ORIGINS=http://localhost:3000

# --- OpenRouter (vision temperature extraction + report text) ---
OPENROUTER_API_KEY=
OPENROUTER_VISION_MODEL=google/gemini-2.5-flash
OPENROUTER_TEXT_MODEL=anthropic/claude-sonnet-4
OPENROUTER_APP_URL=https://thermaleye.app
OPENROUTER_APP_TITLE=ThermalEye

# --- Supabase Storage ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=thermaleye

# --- Email / alerts (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="ThermalEye Alerts <alerts@thermaleye.app>"
# Fallback alert recipient when an org hasn't configured its own
DEFAULT_ALERT_RECIPIENT=singhpranav431@gmail.com

# --- Weather (ambient temperature enrichment, optional) ---
WEATHER_API_KEY=
